SELECT 'CREATE SYNONYM shopro.' || table_name || ' FOR CREATOR.' || table_name || ';' 
FROM all_tables 
WHERE owner = 'CREATOR' and table_name like 'SH_%'
                        and table_name not in ('SH_PROD_DEL', 'SH_PROD_LIKE');
                        
