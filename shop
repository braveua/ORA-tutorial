--ALTER USER shopro IDENTIFIED BY "НовыйСложныйПароль123";
CREATE ROLE shoprolero;
GRANT CREATE SESSION TO shoprolero;
GRANT shoprolero TO shopro;
--------------------------------------------------------------------

SELECT 'GRANT SELECT ON CREATOR.' || table_name || ' TO shoprolero;' 
FROM all_tables 
WHERE owner = 'CREATOR' 
  and table_name like 'SH_%'
  and table_name not in ('SH_PROD_DEL', 'SH_PROD_LIKE');

